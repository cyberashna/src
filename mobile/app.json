{
  "expo": {
    "name": "Habit Planner",
    "slug": "habit-planner-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.habitplanner.mobile"
    },
    "android": {
      "package": "com.habitplanner.mobile"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ]
  }
}
